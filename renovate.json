{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Rome",
  "schedule": [
    "before 6am on monday"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "deno"
      ],
      "groupName": "deno dependencies",
      "schedule": [
        "before 6am on monday"
      ],
      "automerge": true
    }
  ],
  "commitMessagePrefix": "chore(deps): ",
  "commitMessageTopic": "{{#if isPin}}pin{{else}}update{{/if}} {{depName}}",
  "commitMessageExtra": "{{#if isPinDigest}}to {{{newDigestShort}}}{{else}}{{#if isMajor}}to v{{newMajor}}{{else}}{{#if isSingleVersion}}to {{newVersion}}{{else}}{{newValue}}{{/if}}{{/if}}{{/if}}",
  "labels": [
    "dependencies"
  ]
}
