{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "timezone": "Europe/Rome",
    "schedule": [
        "before 6am on monday"
    ],
    "packageRules": [
        {
            "matchDatasources": [
                "deno"
            ],
            "groupName": "deno dependencies",
            "schedule": [
                "before 6am on monday"
            ],
            "automerge": true
        }
    ],
    "prTitle": "chore(deps): {{semanticPrefix}}{{#if isPin}}pin{{else}}update{{/if}} {{depName}} {{#if isPinDigest}}{{{newDigestShort}}}{{else}}{{#if isMajor}}to v{{newMajor}}{{else}}{{#if isSingleVersion}}to {{newVersion}}{{else}}{{newValue}}{{/if}}{{/if}}{{/if}}",
    "commitMessagePrefix": "chore(deps): ",
    "labels": [
        "dependencies"
    ]
}